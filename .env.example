# Root-level reference. Actual env files live in frontend/.env.local and backend/.env.

# --- Supabase (shared) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key   # backend only, never expose to frontend

# --- AI ---
HF_API_TOKEN=hf_xxx                           # https://huggingface.co/settings/tokens

# --- URLs (for wiring the two services together) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000
